{
  "manifest_version": 3,
  "name": "Grid Lens",
  "version": "1.0.0",
  "description": "Inspect any webpage's visual grid, typography, and colors. Export design tokens as Markdown.",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel", "contextMenus"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "commands": {
    "toggle-grid": {
      "suggested_key": { "default": "Alt+G" },
      "description": "Toggle pixel grid"
    },
    "toggle-inspect": {
      "suggested_key": { "default": "Alt+I" },
      "description": "Toggle inspect mode"
    },
    "toggle-rulers": {
      "suggested_key": { "default": "Alt+R" },
      "description": "Toggle rulers"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
